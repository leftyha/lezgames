# PostgreSQL database used by Prisma.
DATABASE_URL="postgresql://lezgamez:lezgamez@localhost:5432/lezgamez?schema=public"

# Redis is used for rate limiting and short-lived runtime guards.
# If omitted locally, the API falls back to in-memory rate limiting for development only.
REDIS_URL="redis://localhost:6379"

# Must match NEXT_PUBLIC_SCORE_CHECKSUM_SALT while the MVP checksum is still client-computed.
# Replace this with server-signed score tokens in the next security pass.
SCORE_CHECKSUM_SALT="lezgamez-mvp"

# API port.
PORT=4000
